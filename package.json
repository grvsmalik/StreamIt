{
  "name": "streamit",
  "version": "0.2.0",
  "description": "A browser built for watching non-DRM and personal media with friends over Discord",
  "author": "StreamIt",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "gen:icons": "node scripts/gen-icons.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package:dir": "electron-vite build && electron-builder --dir",
    "package": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "devDependencies": {
    "@heroui/react": "^3.2.2",
    "@heroui/styles": "^3.2.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^3.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.1",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "webtorrent": "^3.0.16"
  }
}
